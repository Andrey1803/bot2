# Telegram Bot Token (обязательно)
API_TOKEN=ваш_токен_бота

# YouGile API Key (обязательно)
YOUGILE_API_KEY=ваш_api_ключ_yougile

# ID колонки в YouGile для создания задач (обязательно)
COLUMN_ID=id_колонки

# Telegram ID администратора (необязательно)
ADMIN_ID=123456789

# ID проекта YouGile (необязательно, для утилит)
PROJECT_ID=id_проекта

# Секрет для проверки вебхуков от YouGile (необязательно, но рекомендуется)
YOUGILE_WEBHOOK_SECRET=ваш_секрет_для_вебхука

# --- Интеграция с «Диспетчер задач» (опционально) ---
# Публичный URL API диспетчера, например https://dispatcher-api.up.railway.app
DISPATCHER_API_URL=
# Ключ из DISPATCHER_INBOUND_API_KEY на стороне API диспетчера
DISPATCHER_INBOUND_API_KEY=
# Один из двух вариантов маршрутизации:
# 1) Напрямую в существующую группу
DISPATCHER_GROUP_ID=
# 2) Автоподбор/создание компании + группы (если GROUP_ID не задан)
DISPATCHER_COMPANY_NAME=
DISPATCHER_GROUP_NAME=Заявки Telegram
