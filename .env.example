# Telegram Bot Token (обязательно)
API_TOKEN=ваш_токен_бота

# YouGile API Key (обязательно)
YOUGILE_API_KEY=ваш_api_ключ_yougile

# ID колонки в YouGile для создания задач (обязательно)
COLUMN_ID=id_колонки

# Telegram ID администратора (необязательно)
ADMIN_ID=123456789

# ID проекта YouGile (необязательно, для утилит)
PROJECT_ID=id_проекта

# Секрет для проверки вебхуков от YouGile (необязательно, но рекомендуется)
YOUGILE_WEBHOOK_SECRET=ваш_секрет_для_вебхука
